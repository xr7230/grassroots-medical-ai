# DeepSeek API配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
CHROMA_DB_PATH=./data/chroma

# 日志配置
LOG_LEVEL=INFO

# 版本二新增配置
# 公卫系统对接
PUBLIC_HEALTH_API_URL=http://localhost:9000/api
PUBLIC_HEALTH_ENABLED=true

# HIS系统对接
HIS_API_URL=http://localhost:9001/api
HIS_ENABLED=false

# 安全配置
ENABLE_AUDIT_LOG=true
ENABLE_DATA_ENCRYPTION=true
ENABLE_OFFLINE_MODE=true

# AI辅助配置
ENABLE_AI_SUGGESTION=true
AI_SUGGESTION_CONSERVATIVE=true

# 阿里云语音识别配置
# 实时语音识别 (NLS - Natural Language Service)
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id_here
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret_here
# 请在阿里云控制台创建项目后获取 AppKey
# https://nls-portal.console.aliyun.com/applist
ALIYUN_NLS_APP_KEY=your_app_key_here
# 语音识别服务地址（实时识别）
ALIYUN_NLS_URL=wss://nls-gateway-cn-shanghai.aliyuncs.com/ws/v1
# 是否使用阿里云语音识别（true=使用阿里云，false=使用本地Whisper）
USE_ALIYUN_ASR=true
